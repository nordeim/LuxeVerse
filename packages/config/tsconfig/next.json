{
  "extends": "./base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@ui/*": [../../packages/ui/src/*"],
      "@utils/*": ["../../packages/utils/src/*"]
